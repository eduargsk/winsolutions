---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseCard from "../components/CourseCard.astro";
import coursesData from "../data/courses.json";
import { Image } from "astro:assets";

// RECURSOS NATIVOS
import devImg from "../assets/images/dev_balanced.png";
import openSourceImg from "../assets/images/open-source.png";

const pageTitle = "WinSolutions | Domina las Tecnologías del Futuro";
const pageDescription = "Rutas de aprendizaje estructuradas paso a paso en Ingeniería de Software y Ciberseguridad.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  
  <section class="relative overflow-hidden pt-24 pb-16 md:pt-32 md:pb-24 bg-white dark:bg-slate-950 transition-colors duration-300">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-cyan-500/10 rounded-full blur-[120px] -z-10"></div>
    <div class="absolute top-20 right-1/4 w-72 h-72 bg-purple-500/5 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center max-w-4xl">
      <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-bold bg-cyan-500/10 text-cyan-600 dark:text-cyan-400 border border-cyan-500/20 mb-6 uppercase tracking-wider">
        🚀 Impulsa tu Perfil Profesional
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.15] mb-6">
        Domina las Tecnologías que Mueven el <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-500 to-blue-600 dark:from-cyan-400 dark:to-blue-500">Mundo Digital</span>
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-10">
        Rutas de aprendizaje estructuradas paso a paso en Ingeniería de Software y Ciberseguridad. Olvídate de tutoriales sueltos y aprende con una metodología directa al grano.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="#cursos" class="inline-flex w-full sm:w-auto items-center justify-center py-3.5 px-8 text-sm font-bold text-white bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl shadow-lg shadow-cyan-500/10 transition-all duration-200 transform hover:scale-[1.01]">
          Explorar Cursos
        </a>
        <a href="#metodologia" class="inline-flex w-full sm:w-auto items-center justify-center py-3.5 px-8 text-sm font-semibold text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl transition-all duration-200 hover:bg-slate-200 dark:hover:bg-slate-800/60">
          Nuestra Metodología
        </a>
      </div>
    </div>
  </section>

    <section id="metodologia" class="py-16 bg-slate-50/50 dark:bg-slate-900/20 border-t border-slate-100 dark:border-slate-900/60 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-xs font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-widest">Metodología de Aprendizaje</span>
          <h2 class="mt-2 text-3xl font-bold text-slate-900 dark:text-white tracking-tight sm:text-4xl">Aprende desde Cero y a tu Ritmo</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-400 leading-relaxed">
            Nuestros cursos están diseñados para que no necesites conocimientos previos. Cada módulo incluye clases en vídeo, ejercicios prácticos y proyectos reales que construyes paso a paso. Nosotros te damos el camino, las herramientas y el soporte técnico, pero el éxito depende de ti: practica constantemente, mantén la disciplina y construye tu futuro con resultados tangibles.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-cyan-500 dark:text-cyan-400 font-bold text-lg">🔐</span>
              <span><strong class="font-bold">Acceso vitalicio:</strong> Las clases quedan grabadas para que las repases cuantas veces necesites, sin vencimientos.</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-cyan-500 dark:text-cyan-400 font-bold text-lg">🌍</span>
              <span><strong class="font-bold">Flexibilidad total:</strong> Estudia desde cualquier país, en la comodidad de tu casa y desde tu dispositivo favorito (celular, tablet o computadora).</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-cyan-500 dark:text-cyan-400 font-bold text-lg">🛠️</span>
              <span><strong class="font-bold">Enfoque práctico:</strong> Eliminamos la teoría vacía para centrarnos en lo que realmente funciona, aplicando lo aprendido en laboratorios y ejercicios guiados.</span>
            </li>
          </ul>
        </div>
        <div class="flex justify-center">
          <Image 
            src={devImg} 
            alt="Aprende a tu ritmo" 
            class="w-full max-w-md rounded-2xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-950 p-4 shadow-sm"
          />
        </div>
      </div>
    </div>
  </section>

  <section id="cursos" class="py-16 border-t border-slate-100 dark:border-slate-900/60 bg-white dark:bg-slate-950 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">Certificaciones Profesionales</h2>
        <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">Selecciona tu área y desglosa los módulos técnicos completos de cada formación antes de inscribirte.</p>
      </div>

      <div class="flex flex-wrap justify-center gap-2 mb-12 max-w-md mx-auto p-1 bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl transition-colors duration-300">
        <button data-filter="all" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-bold bg-cyan-500 text-slate-950 shadow-sm transition-all duration-200">
          Todos
        </button>
        <button data-filter="Frontend" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors duration-200">
          Frontend
        </button>
        <button data-filter="Backend" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors duration-200">
          Backend
        </button>
        <button data-filter="Ciberseguridad" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors duration-200">
          Seguridad
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {coursesData.map((course) => (
          <div data-category={course.category} class="course-item block transition-all duration-200">
            <CourseCard {...course} />
          </div>
        ))}
      </div>
    </div>
  </section>

    <section class="py-16 bg-white dark:bg-slate-950 border-t border-slate-100 dark:border-slate-900/60 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 flex justify-center">
          <Image 
            src={openSourceImg} 
            alt="Certificado y Comunidad" 
            class="w-full max-w-md rounded-2xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-950 p-4 shadow-sm"
          />
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest">Experiencia WinSolutions</span>
          <h2 class="mt-2 text-3xl font-bold text-slate-900 dark:text-white tracking-tight sm:text-4xl">Más allá de solo ver vídeos</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-400 leading-relaxed">
            Diseñamos tu ruta de aprendizaje para que no solo consumas información, sino que construyas habilidades que las empresas realmente valoran y necesitan en el mercado actual.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-emerald-500 dark:text-emerald-400 font-bold text-lg">🎓</span>
              <span><strong class="font-bold">Certificación de competencias:</strong> Al finalizar tu ruta, obtén un respaldo oficial que demuestra tu dominio técnico en proyectos reales.</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-emerald-500 dark:text-emerald-400 font-bold text-lg">🔄</span>
              <span><strong class="font-bold">Actualización constante:</strong> Tu acceso es ilimitado; si el temario evoluciona con nuevas tecnologías o herramientas, recibirás esas actualizaciones sin costo adicional.</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-emerald-500 dark:text-emerald-400 font-bold text-lg">💬</span>
              <span><strong class="font-bold">Comunidad técnica:</strong> No aprendes solo. Accede a nuestro grupo de apoyo para resolver bloqueos de código, despejar dudas de arquitectura y compartir experiencias con otros estudiantes.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <script>
  // ========== DATOS DEL TEMARIO ==========
  let courseDetailsData = {};

  // ========== FUNCIONES DEL MODAL ==========
  function closeModal(overlay, escListener) {
    if (overlay) {
      overlay.classList.remove('active');
      setTimeout(() => {
        if (overlay && overlay.parentNode) {
          overlay.remove();
        }
      }, 300);
    }
    document.body.classList.remove('modal-open');
    if (escListener) {
      document.removeEventListener('keydown', escListener);
    }
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function openModal(cursoId) {
    const data = courseDetailsData[cursoId];
    
    if (!data) {
      console.error("No se encontraron datos para:", cursoId);
      alert("Lo sentimos, el temario detallado de este curso estará disponible próximamente.");
      return;
    }

    const overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    
    overlay.innerHTML = `
      <div class="modal-container">
        <button class="modal-close" aria-label="Cerrar">✕</button>
        <div class="modal-content">
          <h2 class="modal-title">${escapeHtml(data.title)}</h2>
          <div class="modal-divider"></div>
          
          <div class="modal-section">
            <h3 class="modal-section-title">🎯 ¿A quién va dirigido?</h3>
            <p class="modal-target">${escapeHtml(data.target)}</p>
          </div>
          
          <div class="modal-section">
            <h3 class="modal-section-title">🚀 ¿Qué vas a lograr?</h3>
            <ul class="modal-objectives">
              ${data.objectives.map(obj => `<li>${escapeHtml(obj)}</li>`).join('')}
            </ul>
          </div>
          
          <div class="modal-section">
            <h3 class="modal-section-title">📚 Estructura completa del temario</h3>
            <div class="modal-modules">
              ${data.fullModules.map(mod => `<div class="modal-module-item">${escapeHtml(mod)}</div>`).join('')}
            </div>
          </div>
        </div>
      </div>
    `;

    document.body.appendChild(overlay);
    document.body.classList.add('modal-open');

    setTimeout(() => {
      overlay.classList.add('active');
    }, 10);

    const escListener = (e) => {
      if (e.key === 'Escape') {
        closeModal(overlay, escListener);
      }
    };
    document.addEventListener('keydown', escListener);

    const closeBtn = overlay.querySelector('.modal-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', () => closeModal(overlay, escListener));
    }

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closeModal(overlay, escListener);
      }
    });
  }

  // ========== CARGAR DATOS DEL TEMARIO ==========
  fetch('/data/course-details.json')
    .then(res => {
      if (!res.ok) throw new Error('Error cargando el temario');
      return res.json();
    })
    .then(data => {
      courseDetailsData = data;
      console.log('✅ Temario cargado correctamente', Object.keys(data).length, 'cursos');
    })
    .catch(err => {
      console.error('❌ Error cargando el temario:', err);
    });

  // ========== EVENTO PARA BOTONES "VER TEMARIO" ==========
  document.addEventListener('click', (e) => {
    const button = e.target.closest('.btn-ver-detalle');
    if (!button) return;
    
    e.preventDefault();
    e.stopPropagation();
    
    const cursoId = button.getAttribute('data-id');
    console.log("ID detectado:", cursoId);
    
    if (Object.keys(courseDetailsData).length === 0) {
      console.log("Esperando carga de datos...");
      const waitForData = setInterval(() => {
        if (Object.keys(courseDetailsData).length > 0) {
          clearInterval(waitForData);
          openModal(cursoId);
        }
      }, 100);
      setTimeout(() => {
        clearInterval(waitForData);
        if (Object.keys(courseDetailsData).length === 0) {
          alert("Error cargando el temario. Por favor, recarga la página.");
        }
      }, 5000);
      return;
    }
    
    openModal(cursoId);
  });

  // ========== FILTROS DE CATEGORÍAS (TABS) ==========
  const tabButtons = document.querySelectorAll('.tab-btn');
  const courseItems = document.querySelectorAll('.course-item');

  function initFilters() {
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');

        // Actualizar estilos de los botones
        tabButtons.forEach(btn => {
          btn.classList.remove('bg-cyan-500', 'text-slate-950', 'shadow-sm', 'font-bold');
          btn.classList.add('text-slate-500', 'dark:text-slate-400', 'font-medium');
        });
        
        button.classList.add('bg-cyan-500', 'text-slate-950', 'shadow-sm', 'font-bold');
        button.classList.remove('text-slate-500', 'dark:text-slate-400', 'font-medium');

        // Filtrar cursos
        courseItems.forEach(item => {
          const itemCategory = item.getAttribute('data-category');
          if (filter === 'all' || itemCategory === filter) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
  }

  // Inicializar filtros cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFilters);
  } else {
    initFilters();
  }
</script>
  
  <!-- SECCIÓN 5: GARANTÍA DE SATISFACCIÓN (Arregla el enlace del menú superior) -->
  <section id="garantia" class="py-20 border-t border-slate-100 dark:border-slate-900/60 bg-white dark:bg-slate-950 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/20 mb-6 animate-pulse">
        <!-- Icono de Escudo/Sello de Garantía -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
        </svg>
      </div>
      
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
        Garantía de Satisfacción Total
      </h2>
      
      <p class="mt-4 text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Prueba la ruta de formación que elijas durante <span class="text-amber-600 dark:text-amber-400 font-bold">7 días completos</span>. Si sientes que el contenido, los laboratorios o la estructura no cumplen con tus expectativas de crecimiento profesional, puedes solicitar el reembolso del 100% de tu dinero de manera inmediata a través de la plataforma de Hotmart. Sin preguntas, sin riesgos.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-6 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest">
        <span class="flex items-center gap-1.5">🔒 Compra Segura</span>
        <span class="flex items-center gap-1.5">💳 Respaldo Hotmart</span>
        <span class="flex items-center gap-1.5">🚀 Acceso Inmediato</span>
      </div>
    </div>
  </section>

  <script>
  

  // Usamos 'delegación de eventos': escuchamos clics en el DOCUMENTO
  document.addEventListener('click', (e) => {
    // Buscamos si lo que se clickeó es nuestro botón
    const target = e.target as HTMLElement;
    const button = target.closest('.btn-ver-detalle');

    if (!button) return; // Si no es el botón, no hacemos nada

    const id = button.getAttribute('data-id');
    console.log("ID detectado al hacer clic:", id); // <-- SI ESTO SALE, EL BOTÓN FUNCIONA

    const data = (courseDetailsData as any)[id as string];

    if (data) {
      const section = document.getElementById('detalle-curso-seccion');
      if (section) {
        document.getElementById('detalle-titulo')!.textContent = data.title;
        document.getElementById('detalle-target')!.textContent = data.target;
        
        const objList = document.getElementById('detalle-objetivos');
        if (objList) {
          objList.innerHTML = data.objectives.map((o: string) => `<li>${o}</li>`).join('');
        }

        const modContainer = document.getElementById('detalle-modulos-container');
        if (modContainer) {
          modContainer.innerHTML = data.fullModules.map((m: string) => 
            `<div class="bg-[#0f172a] p-3 rounded-lg text-sm border-l-4 border-cyan-400 text-slate-300 font-medium shadow-sm">${m}</div>`
          ).join('');
        }

        section.classList.remove('hidden');
        section.scrollIntoView({ behavior: 'smooth' });
      }
    } else {
      console.error("No se encontró data en el JSON para el ID:", id);
    }
  });
</script>


<style is:global>
  /* ESTILOS DEL MODAL */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* Modal container - modo claro (gris suave) por defecto */
  .modal-container {
    max-width: 700px;
    width: 90%;
    max-height: 85vh;
    background: #f5f5f0;
    border-radius: 24px;
    overflow-y: auto;
    transform: scale(0.9);
    transition: transform 0.3s ease;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    position: relative;
  }

  .modal-overlay.active .modal-container {
    transform: scale(1);
  }

  /* Modo oscuro automático */
  @media (prefers-color-scheme: dark) {
    .modal-container {
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
      border: 1px solid rgba(59, 130, 246, 0.3);
    }
  }

  /* Botón cerrar */
  .modal-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: rgba(0, 0, 0, 0.1);
    border: none;
    font-size: 28px;
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: #334155;
  }

  @media (prefers-color-scheme: dark) {
    .modal-close {
      background: rgba(255, 255, 255, 0.1);
      color: #cbd5e1;
    }
  }

  .modal-close:hover {
    background: rgba(0, 0, 0, 0.2);
    transform: rotate(90deg);
  }

  @media (prefers-color-scheme: dark) {
    .modal-close:hover {
      background: rgba(255, 255, 255, 0.2);
    }
  }

  /* Contenido interno del modal */
  .modal-content {
    padding: 2rem;
  }

  .modal-title {
    font-size: 28px;
    font-weight: bold;
    margin-bottom: 12px;
    color: #0f172a;
    padding-right: 32px;
  }

  @media (prefers-color-scheme: dark) {
    .modal-title {
      background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  }

  .modal-divider {
    height: 4px;
    width: 80px;
    background: #3b82f6;
    border-radius: 2px;
    margin-bottom: 24px;
  }

  .modal-section {
    margin-bottom: 24px;
  }

  .modal-section-title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #1e293b;
  }

  @media (prefers-color-scheme: dark) {
    .modal-section-title {
      color: #e2e8f0;
    }
  }

  .modal-target {
    color: #475569;
    line-height: 1.5;
    font-size: 14px;
  }

  @media (prefers-color-scheme: dark) {
    .modal-target {
      color: #94a3b8;
    }
  }

  .modal-objectives {
    list-style: none;
    padding-left: 0;
  }

  .modal-objectives li {
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #334155;
    font-size: 14px;
  }

  @media (prefers-color-scheme: dark) {
    .modal-objectives li {
      color: #cbd5e1;
    }
  }

