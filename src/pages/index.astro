---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseCard from "../components/CourseCard.astro";
import coursesData from "../data/courses.json";
import CourseDetailsSection from "../components/CourseDetailsSection.astro";

import { Image } from "astro:assets";

// RECURSOS NATIVOS
import devImg from "../assets/images/dev_balanced.png";
import openSourceImg from "../assets/images/open-source.png";

const pageTitle = "WinSolutions | Domina las Tecnologías del Futuro";
const pageDescription = "Rutas de aprendizaje estructuradas paso a paso en Ingeniería de Software y Ciberseguridad.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  
  <section class="relative overflow-hidden pt-24 pb-16 md:pt-32 md:pb-24 bg-white dark:bg-slate-950 transition-colors duration-300">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-cyan-500/10 rounded-full blur-[120px] -z-10"></div>
    <div class="absolute top-20 right-1/4 w-72 h-72 bg-purple-500/5 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center max-w-4xl">
      <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-bold bg-cyan-500/10 text-cyan-600 dark:text-cyan-400 border border-cyan-500/20 mb-6 uppercase tracking-wider">
        🚀 Impulsa tu Perfil Profesional
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.15] mb-6">
        Domina las Tecnologías que Mueven el <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-500 to-blue-600 dark:from-cyan-400 dark:to-blue-500">Mundo Digital</span>
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-10">
        Rutas de aprendizaje estructuradas paso a paso en Ingeniería de Software y Ciberseguridad. Olvídate de tutoriales sueltos y aprende con una metodología directa al grano.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="#cursos" class="inline-flex w-full sm:w-auto items-center justify-center py-3.5 px-8 text-sm font-bold text-white bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl shadow-lg shadow-cyan-500/10 transition-all duration-200 transform hover:scale-[1.01]">
          Explorar Cursos
        </a>
        <a href="#metodologia" class="inline-flex w-full sm:w-auto items-center justify-center py-3.5 px-8 text-sm font-semibold text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl transition-all duration-200 hover:bg-slate-200 dark:hover:bg-slate-800/60">
          Nuestra Metodología
        </a>
      </div>
    </div>
  </section>

  <section id="metodologia" class="py-16 bg-slate-50/50 dark:bg-slate-900/20 border-t border-slate-100 dark:border-slate-900/60 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-xs font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-widest">Enfoque de Ingeniería</span>
          <h2 class="mt-2 text-3xl font-bold text-slate-900 dark:text-white tracking-tight sm:text-4xl">Educación Balanceada y Estructurada</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-400 leading-relaxed">
            Nuestras rutas de formación están diseñadas por ingenieros para futuros profesionales. No te damos teoría vacía; equilibramos los fundamentos de la computación con laboratorios intensivos en entornos reales de desarrollo y auditoría.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-cyan-500 dark:text-cyan-400 font-bold">⚡</span> Clases dinámicas centradas en la resolución de problemas locales.
            </li>
            <li class="flex items-center gap-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="text-cyan-500 dark:text-cyan-400 font-bold">⚡</span> Despliegue de código limpio y auditorías éticas de sistemas.
            </li>
          </ul>
        </div>
        <div class="flex justify-center">
          <Image 
            src={devImg} 
            alt="Desarrollo Balanceado" 
            class="w-full max-w-md rounded-2xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-950 p-4 shadow-sm"
          />
        </div>
      </div>
    </div>
  </section>

  <section id="cursos" class="py-16 border-t border-slate-100 dark:border-slate-900/60 bg-white dark:bg-slate-950 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">Certificaciones Profesionales</h2>
        <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">Selecciona tu área y desglosa los módulos técnicos completos de cada formación antes de inscribirte.</p>
      </div>

      <div class="flex flex-wrap justify-center gap-2 mb-12 max-w-md mx-auto p-1 bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl transition-colors duration-300">
        <button data-filter="all" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-bold bg-cyan-500 text-slate-950 shadow-sm transition-all duration-200">
          Todos
        </button>
        <button data-filter="Frontend" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors duration-200">
          Frontend
        </button>
        <button data-filter="Backend" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors duration-200">
          Backend
        </button>
        <button data-filter="Ciberseguridad" class="tab-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors duration-200">
          Seguridad
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {coursesData.map((course) => (
          <div data-category={course.category} class="course-item block transition-all duration-200">
            <CourseCard {...course} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CourseDetailsSection />

  <section class="py-16 bg-slate-50/50 dark:bg-slate-900/20 border-t border-slate-100 dark:border-slate-900/60 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 flex justify-center">
          <Image 
            src={openSourceImg} 
            alt="Código Abierto y Recursos" 
            class="w-full max-w-md rounded-2xl border border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-950 p-4 shadow-sm"
          />
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest">Recursos Abiertos</span>
          <h2 class="mt-2 text-3xl font-bold text-slate-900 dark:text-white tracking-tight sm:text-4xl">Portafolios reales en GitHub</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-400 leading-relaxed">
            Creemos firmemente en el poder del código abierto y los repositorios limpios. Cada proyecto final que construyas a lo largo de las rutas de desarrollo o los reportes de vulnerabilidad que generes en ciberseguridad, se subirán directamente a tu cuenta de GitHub con arquitecturas de nivel profesional listas para presentar en entrevistas técnicas laborales.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
  // Datos del temario inyectados directamente (tomados de tu JSON)
  const courseDetailsData = {
    "html-css": {
      "title": "Diseño Web Moderno con HTML5 y CSS3",
      "target": "Aquellas personas que están dando sus primeros pasos en el mundo del desarrollo web, diseño o marketing digital y desean dominar los cimientos de la maquetación profesional sin conocimientos previos.",
      "objectives": [
        "Aprenderás las bases fundamentales de cómo funciona la web utilizando etiquetas semánticas (HTML5).",
        "Darás formato estético e impacto visual moderno utilizando hojas de estilo (CSS3).",
        "Aprenderás a estructurar de forma limpia barras de navegación, formularios avanzados y secciones multimedia.",
        "Dominarás los sistemas de diseño responsive avanzados: Flexbox y CSS Grid.",
        "Aprenderás la integración práctica y avanzada de Bootstrap 5 para acelerar tus flujos de desarrollo."
      ],
      "fullModules": [
        "MOD.1 Bienvenida y explicación de la estructura del curso.",
        "MOD.2 Fundamentos teóricos: Instalación de VS Code, ¿Qué es HTML? y sus elementos.",
        "MOD.3 HTML5: Etiquetas semánticas, imágenes, rutas absolutas/relativas, formularios y multimedia.",
        "MOD.4 CSS: Estilos, selectores, colores, fuentes, fondos y pseudo-clases.",
        "BONO.1 Cierre del módulo - Proyecto Final Realizado.",
        "BONO.2 Recursos de apoyo descargables en Drive y GitHub.",
        "BONO.3 Flexbox: Conceptos técnicos, aplicaciones y práctica real.",
        "BONO.4 CSS Grid: Conceptos, aplicaciones y usos prácticos en interfaces.",
        "MOD.5 Bootstrap-5: Conceptos técnicos, layouts y aplicaciones prácticas avanzados."
      ]
    },
    "js-basico": {
      "title": "Desarrollo Web con JavaScript (Inicial a Intermedio)",
      "target": "Estudiantes y maquetadores que ya conocen HTML y CSS, y quieren dar el salto definitivo hacia la programación web dotando a sus interfaces de lógica, dinamismo, eventos e interactividad real.",
      "objectives": [
        "Dominarás la sintaxis esencial de JavaScript: variables, operadores aritméticos y lógicos.",
        "Aprenderás a controlar el flujo de tus aplicaciones con estructuras de control condicionales y bucles (for, while, do..while).",
        "Aprenderás a crear funciones declaradas, expresadas y Arrow functions manejando el Scope correctamente.",
        "Manipularás e interactuarás con cada uno de los elementos de tus documentos HTML por medio del DOM (Modelo de Objetos del Documento).",
        "Aprenderás a aplicar estilos dinámicos, gestionar clases de CSS y escuchar eventos del usuario en tiempo real."
      ],
      "fullModules": [
        "MOD.1 Introducción al lenguaje y configuración de herramientas a utilizar.",
        "MOD.2 Conociendo el lenguaje e incorporación en un archivo HTML.",
        "MOD.3 Primeras interacciones: Variables (var, let, const), tipos de datos y operadores.",
        "MOD.4 Interactuando con el lenguaje: alert(), prompt() y confirm().",
        "MOD.5 Estructuras de control: Sentencias condicionales (if, else, switch) y bucles.",
        "MOD.6 Funciones: Declaradas, expresadas, Arrow functions y Scope de variables.",
        "MOD.7 Callbacks y sus aplicaciones fundamentales.",
        "MOD.8 Métodos avanzados de strings.",
        "MOD.9 Plantillas literarias e interpolación de expresiones (Template Literals).",
        "MOD.10 Arrays: Simples, multidimensionales y recorridos con ciclos.",
        "MOD.11 Métodos esenciales de los arrays (.push, .pop, .shift, .unshift, .slice).",
        "MOD.12 Entendiendo el Objeto window y el objeto document.",
        "MOD.13 Modelo de Objeto del Documento (DOM) y Selectores avanzados.",
        "MOD.14 Modificando el DOM de forma interactiva: innertext e innerhtml.",
        "MOD.15 Aplicando estilos dinámicos desde JavaScript.",
        "MOD.16 Aplicando y gestionando clases de CSS dinámicamente.",
        "MOD.17 Trabajando con eventos y capturas del usuario.",
        "MOD.18 Modificando atributos de elementos HTML en tiempo real.",
        "BONO.1 Desarrollo completo del Proyecto Final práctico.",
        "BONO.2 Material de apoyo de las clases listo en Drive y GitHub."
      ]
    },
    "js-avanzado": {
      "title": "JavaScript Desarrollo Web Avanzado",
      "target": "Programadores web que tienen una base sólida de JavaScript y necesitan dominar la asincronía, el consumo de datos externos y la persistencia del lado del cliente para construir aplicaciones profesionales.",
      "objectives": [
        "Aprenderás a controlar el tiempo en tus aplicaciones usando Timers (setTimeout, setInterval).",
        "Dominarás los métodos avanzados de arrays indispensables en el desarrollo moderno (.map, .filter, .reduce, .find).",
        "Aprenderás a formatear y estructurar datos mediante JSON de forma nativa.",
        "Dominarás las peticiones asíncronas en la web consumiendo APIs externas por medio de Fetch.",
        "Aprenderás a guardar información persistente en el navegador usando sessionStorage y localStorage."
      ],
      "fullModules": [
        "MOD.1 Introducción al curso avanzado y herramientas de desarrollo.",
        "MOD.2 Objeto Date y manipulación de fechas del sistema.",
        "MOD.3 Timers globales: setTimeOut, setInterval y clearInterval.",
        "MOD.4 Objetos literales: Construcción avanzada, accesos y utilidades.",
        "MOD.5 Métodos avanzados de arrays (.forEach, for...of, .map, .filter, .find, .reduce).",
        "MOD.6 JavaScript Object Notation (JSON.stringify y JSON.parse).",
        "MOD.7 Manejo de eventos del lado del cliente, preventDefault y validación avanzada de formularios.",
        "MOD.8 Qué son las APIs (Application Programming Interface) y su rol en la web.",
        "MOD.9 Pedidos asíncronos en la web moderna - Uso avanzado de API Fetch (Parte I y II).",
        "MOD.10 Persistencia de datos local: sessionStorage y localStorage (.setItem, .getItem, .clear).",
        "MOD.11 Objeto location y captura de datos de query string.",
        "BONO.1 Uso e implementación técnica de librerías en JavaScript."
      ]
    },
    "nodejs": {
      "title": "Ingeniería Backend con Node.js",
      "target": "Desarrolladores o estudiantes que ya cuentan con bases sólidas de JavaScript, HTML5 y CSS3, y buscan dominar el entorno del servidor para crear arquitecturas comerciales completas.",
      "objectives": [
        "Conocerás todo el ecosistema ofrecido por Node.js, configurando módulos nativos, propios y de terceros (NPM).",
        "Aprenderás a estructurar proyectos limpios bajo el patrón de arquitectura Modelo Vista Controlador (MVC).",
        "Dominarás el desarrollo de servidores web eficientes usando el framework Express y el motor de plantillas EJS.",
        "Aprenderás a diseñar y consultar bases de datos relacionales integrando el motor MySQL de forma nativa.",
        "Construirás un CRUD robusto mapeando tus tablas con el ORM Sequelize (.create, .update, .destroy).",
        "Aprenderás a manejar subida de archivos (Multer), validaciones (Express Validator), Middlewares y sesiones/cookies."
      ],
      "fullModules": [
        "MOD.1 Bienvenida al curso y explicación detallada de la ruta de aprendizaje.",
        "MOD.2 ¿Qué es NodeJS? e Instalación en el sistema.",
        "MOD.3 Creando un proyecto desde cero y configuración inicial.",
        "MOD.4 Manejo de módulos nativos, de terceros y módulos propios.",
        "MOD.5 Métodos de peticiones HTTP fundamentales.",
        "MOD.6 Patrón de arquitectura de software: Modelo - Vista - Controlador (MVC).",
        "MOD.7 Creando un proyecto con Express, estructura profesional de carpetas y MVC.",
        "MOD.8 Rutas: Sistema de ruteo avanzado y rutas parametrizadas.",
        "MOD.9 Templates Engine: Motor de plantilla EJS, archivos parciales y paso de parámetros.",
        "MOD.10 Introducción técnica a Bases de Datos.",
        "MOD.11 Diseñando nuestra base de datos relacional paso a paso.",
        "MOD.12 Motor MySQL: Estructuras, tablas, claves, consultas y filtros (WHERE, LIKE, ORDER BY).",
        "MOD.13 Mapeador Relacional ORM: Instalación y configuración de Sequelize, modelos y promesas.",
        "MOD.14 Construyendo un CRUD integrado con Sequelize (.create, .findAll, .update, .destroy).",
        "MOD.15 Subiendo archivos al servidor configurando Multer y registrando rutas en la BD.",
        "MOD.16 Validaciones del lado del servidor usando Express Validator y manejo de errores de entrada.",
        "MOD.17 Trabajando con Middlewares globales y de aplicación por ruta específica.",
        "MOD.18 Trabajando con las sesiones de usuarios (session) para persistencia en servidor.",
        "MOD.19 Guardando y consumiendo datos seguros en el navegador del usuario (cookies).",
        "MOD.20 Cierre: Proyecto integrado finalizado y funcional."
      ]
    },
    "ciberseguridad-cero": {
      "title": "Especialización: Seguridad Informática desde Cero (Nivel 1)",
      "target": "Apasionados de la tecnología, administradores de sistemas o desarrolladores que desean introducirse de manera seria y ética en la seguridad digital, aprendiendo las tácticas de ataque para ejecutar defensas corporativas implacables.",
      "objectives": [
        "Aprenderás a configurar laboratorios de pruebas controlados e instalar Kali Linux en entornos virtuales.",
        "Comprenderás la teoría de redes esencial: Direcciones IP, MAC y los pilares de la seguridad de la información.",
        "Aprenderás el funcionamiento de la Ingeniería Social y ataques de Phishing para auditar comportamientos y mitigar riesgos.",
        "Analizarás la creación de Malware táctico (Troyanos y Keyloggers en Python) para auditar vulnerabilidades en sistemas operativos.",
        "Aprenderás técnicas de auditoría inalámbrica (Wi-Fi), cracking de contraseñas por fuerza bruta y anonimato completo en la red."
      ],
      "fullModules": [
        "01. Instalación de Entorno de Trabajo de Auditoría (Virtual Box, Kali Linux y comandos esenciales de terminal).",
        "02. Instalación de Herramientas para Programar Scripts (Python 3 y Visual Studio Code).",
        "03. Teoría fundamental: Direcciones IP, Direcciones MAC y pilares de la Seguridad de la información.",
        "04. Phishing e Ingeniería Social avanzada (Uso de YPhish, PyPhisher, NGROK, SETOOLKIT, ocultación de enlaces y mitigación).",
        "05. Malware de Auditoría: Creación de Troyanos, Keyloggers en Python compilados a EXE, accesos inversos en Java, Word y GO.",
        "06. Ataques en Redes locales y remotas: Uso de Netcat, Web Shells php, reverse shell con Powershell, ataques DOS y ARP Poisoning MITM.",
        "07. Cracking de Contraseñas y hashes: John The Ripper, uso de Wordlists en Kali, generador Cupp, y fuerza bruta con Hydra (FTP, SSH, Gmail).",
        "08. Ataques en Redes Inalámbricas (Wi-Fi): Configuración de tarjeta en modo monitor, cambio de dirección MAC, captura de Handshake y DeAuth Attack WPA/WPA2.",
        "09. Medidas de Seguridad Defensiva: Configuración de Firewalls, detección de WAF, creación de contraseñas robustas y auditoría de Antivirus.",
        "10. Técnicas de Anonimato Completo en la Red y bases de Hacking Corporativo."
      ]
    },
    "ciberseguridad-experto": {
      "title": "Especialización: Experto en Ciberseguridad (Nivel 2)",
      "target": "Usuarios avanzados y profesionales de TI que buscan consolidar conceptos normativos de ciberseguridad corporativa y dominar herramientas ágiles de análisis técnico de archivos y protección de credenciales.",
      "objectives": [
        "Dominarás las distinciones operativas entre seguridad de la información, seguridad informática y ciberseguridad.",
        "Aprenderás a identificar las clasificaciones modernas de amenazas de malware y perfiles de intrusión.",
        "Utilizarás herramientas profesionales de auditoría rápida como VirusTotal para analizar código y comportamientos sospechosos.",
        "Aprenderás a auditar la integridad de credenciales y contraseñas corporativas para detectar fugas o debilidades.",
        "Implementarás configuraciones extremas de privacidad, anonimato y extensiones de seguridad para blindar la navegación web."
      ],
      "fullModules": [
        "01. Introducción: Seguridad de la información, seguridad informática y ciberseguridad. Clasificación de Malwares y amenazas.",
        "02. Módulo 1: Análisis de Vulnerabilidades y tipos, perfiles de atacantes y salidas laborales reales en la industria.",
        "03. Módulo 2: Herramientas de auditoría ágil. Análisis de sitios web y archivos con VirusTotal y rastreo de URLs acortadas.",
        "04. Módulo 3: Comprobación de seguridad en contraseñas corporativas y verificación de credenciales comprometidas en la red.",
        "05. Módulo 4: Privacidad vs anonimato definitivo y configuración de extensiones avanzadas para navegación segura en internet."
      ]
    }
  };

  // Delegación de eventos para el botón "Ver temario completo"
  document.addEventListener('click', (e) => {
    const target = e.target;
    const button = target.closest('.btn-ver-detalle');
    
    if (!button) return;
    
    e.preventDefault();
    e.stopPropagation();
    
    const id = button.getAttribute('data-id');
    console.log("ID detectado:", id);
    
    const data = courseDetailsData[id];
    
    if (data) {
      const section = document.getElementById('detalle-curso-seccion');
      if (section) {
        // Actualizar título
        const tituloElem = document.getElementById('detalle-titulo');
        if (tituloElem) tituloElem.textContent = data.title;
        
        // Actualizar target (audiencia)
        const targetElem = document.getElementById('detalle-target');
        if (targetElem) targetElem.textContent = data.target;
        
        // Actualizar objetivos
        const objetivosElem = document.getElementById('detalle-objetivos');
        if (objetivosElem) {
          objetivosElem.innerHTML = data.objectives.map(obj => `<li>${obj}</li>`).join('');
        }
        
        // Actualizar módulos completos
        const modulosElem = document.getElementById('detalle-modulos-container');
        if (modulosElem) {
          modulosElem.innerHTML = data.fullModules.map(mod => 
            `<div class="bg-[#0f172a] p-3 rounded-lg text-sm border-l-4 border-cyan-400 text-slate-300 font-medium shadow-sm">${mod}</div>`
          ).join('');
        }
        
        // Mostrar sección con animación
        section.classList.remove('hidden');
        section.classList.add('animate-fade-in');
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        
        console.log("✅ Temario cargado correctamente para:", data.title);
      } else {
        console.error("❌ No se encontró la sección #detalle-curso-seccion");
      }
    } else {
      console.error("❌ No se encontraron datos para el ID:", id);
      alert("Lo sentimos, el temario detallado de este curso estará disponible próximamente.");
    }
  });
</script>

  
  <!-- SECCIÓN 5: GARANTÍA DE SATISFACCIÓN (Arregla el enlace del menú superior) -->
  <section id="garantia" class="py-20 border-t border-slate-100 dark:border-slate-900/60 bg-white dark:bg-slate-950 transition-colors duration-300">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/20 mb-6 animate-pulse">
        <!-- Icono de Escudo/Sello de Garantía -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
