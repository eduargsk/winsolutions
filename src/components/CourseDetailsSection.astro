---
import courseDetailsData from '../data/course-details.json';
---

<section id="detalle-curso-seccion" class="hidden max-w-4xl mx-auto my-16 p-1 scroll-mt-24">
  <div class="bg-[#1e293b] text-slate-100 rounded-2xl p-6 md:p-8 shadow-2xl border border-slate-800">
    
    <div class="border-b border-slate-700 pb-4 mb-6">
      <span class="text-xs font-bold text-cyan-400 uppercase tracking-widest">Contenido Detallado</span>
      <h3 id="detalle-titulo" class="text-2xl md:text-3xl font-extrabold text-white mt-1">Título del Curso</h3>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mb-8">
      <div class="bg-slate-900/40 p-5 rounded-xl border border-slate-800/60">
        <h4 class="font-bold text-lg text-emerald-400 mb-3 flex items-center gap-2">
          🎯 ¿A quién va dirigido?
        </h4>
        <p id="detalle-target" class="text-sm text-slate-300 leading-relaxed">
          Descripción de la audiencia ideal...
        </p>
      </div>

      <div class="bg-slate-900/40 p-5 rounded-xl border border-slate-800/60">
        <h4 class="font-bold text-lg text-cyan-400 mb-3 flex items-center gap-2">
          🚀 ¿Qué vas a lograr?
        </h4>
        <ul id="detalle-objetivos" class="list-disc list-inside text-sm text-slate-300 space-y-2">
          </ul>
      </div>
    </div>

    <div>
      <h4 class="font-bold text-lg text-white mb-4 flex items-center gap-2 pb-2 border-b border-slate-800">
        📚 Estructura Completa del Temario
      </h4>
      <div id="detalle-modulos-container" class="space-y-2">
        </div>
    </div>

  </div>
</section>

<style>
  /* Animación suave cuando aparece la sección */
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

